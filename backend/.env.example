# Arbore Web Admin Backend environment (Portainer-backed)
# Copy to .env (or export via compose) and fill in real values.

# ---- Portainer connection ----
# URL of the Portainer CE service. In docker-compose, use the service hostname.
# Example: http://portainer:9000  (HTTP inside the compose network is fine)
PORTAINER_URL=http://portainer:9000

# Portainer API key: Portainer UI -> My account -> API keys -> Create.
# Keep secret; this grants full Docker engine control.
PORTAINER_API_KEY=

# Numeric environment id for the local Docker engine in Portainer.
# Find it in Portainer UI -> Environments, or GET /api/endpoints with the API key.
PORTAINER_ENDPOINT_ID=1

# Set to "false" if Portainer runs with a self-signed HTTPS cert.
PORTAINER_VERIFY_SSL=true

# Default HTTP timeout (seconds) for lightweight calls. Tar upload & image load
# run without a read timeout regardless of this value.
PORTAINER_TIMEOUT=60

# ---- Arbore ----
# Docker network that Arbore compose creates; new custom containers are attached
# to this network automatically (falls back silently if missing).
ARBORE_NETWORK_NAME=arbore-network

# Default Docker restart policy for custom containers.
ARBORE_RESTART_POLICY=unless-stopped

# Absolute project root. Required when the backend runs inside a container and
# needs to read/write config files on the mounted project directory.
# ARBORE_PROJECT_ROOT=/app/project

# Disable OTA update checker (optional).
# ARBORE_OTA_DISABLED=1
