[Unit]
Description=Arbore Web Admin API (uvicorn)
After=network.target

[Service]
Type=simple
User=arbore
Group=arbore
WorkingDirectory=/home/arbore/console/web-admin/backend
Environment="PATH=/home/arbore/console/web-admin/backend/venv/bin"
ExecStart=/home/arbore/console/web-admin/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8002
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
